{
  "expo": {
    "name": "Velo Shipping",
    "slug": "velo-international-shipping",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/android.png",
    "scheme": "velo-international-shipping",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/appstore.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "googleServicesFile": "./GoogleService-Info-velo.plist",
      "config": {
        "usesNonExemptEncryption": false
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.rise.velointernationalshipping",
      "splash": {
        "image": "./assets/images/appstore.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000",
        "dark": {
          "image": "./assets/images/appstore.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      },
      "buildNumber": "22"
    },
    "android": {
      "googleServicesFile": "./google-services-velo.json",
      "versionCode": 8,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/velo-android.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.rise.velointernationalshipping",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/playstore.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBAuth"]
          }
        }
      ],
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "velo-react-native",
          "organization": "rise-ltd"
        }
      ],
      "@sentry/react-native",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.rise.velointernationalshipping"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "81570b4a-bd9f-4abb-9d6e-64b80544cbee"
      }
    }
  }
}
